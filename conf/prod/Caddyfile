{
    email {$LETSENCRYPT_EMAIL}
    acme_ca https://acme-v02.api.letsencrypt.org/directory
    # Optional, faster reload
    # auto_https disable_redirects
}

jan.{$HOST_DOMAIN}, www.{$HOST_DOMAIN}, {$HOST_DOMAIN} {

    log {
        output file /logs/access.log {
            roll_size 10mb
            roll_keep 7
            roll_keep_for 168h
            roll_local_time
        }
    }

    # Match /socket, proxy websocket to goAccess
    reverse_proxy /socket* goaccess:7890

    # /stats/* served by GoAccess service
    handle_path /stats* {
        # Strip /stats prefix, so /stats/index.html → /index.html
        
        # Serve static files from GoAccess HTML output
        root * /usr/share/caddy/html
        try_files {path} /index.html
        file_server
    }

    reverse_proxy web-app:3031
    encode gzip
}
